set dotenv-load := true

compose := "docker-compose"

# Start all services (Label Studio + MLflow + Postgres)
up:
    {{compose}} up -d

# Stop all services
down:
    {{compose}} down

# Tail logs
logs:
    {{compose}} logs -f

# Open Label Studio in browser
ls:
    open http://localhost:8080

# Open MLflow in browser
mlflow:
    open http://localhost:5001

# Backup Label Studio database to datasets/ls_backup_<timestamp>.sql.gz
backup:
    {{compose}} exec postgres pg_dump -U ${POSTGRES_USER:-desktopctl} labelstudio | gzip > datasets/backup/ls_backup_$(date +%Y%m%d_%H%M%S).sql.gz && echo "backed up"

# Open psql in the labelstudio database
psql:
    {{compose}} exec postgres psql -U ${POSTGRES_USER:-desktopctl} labelstudio

# Run a SQL query and print results.
# Usage: just sql "SELECT id, title FROM projects_project"
sql QUERY:
    {{compose}} exec postgres psql -U ${POSTGRES_USER:-desktopctl} labelstudio -c '{{QUERY}}'

# Import a label dir into Label Studio.
# Usage: just import "datasets/path/to/dataset/labels/text_fields" "golden-set"
import DIR PROJECT:
    uv run import/import_batch.py --dir "{{DIR}}" --project "{{PROJECT}}"

# Export accepted labels from LS into a run folder.
# Usage: just run-export 3 text_fields [text_fields]
run-export project_id slug control="":
    uv run run/export_run.py --project-id {{project_id}} --slug {{slug}} \
      $([ -n "{{control}}" ] && echo "--control-type {{control}}" || true)

# Export all tasks from a project (no verdict filter).
# Usage: just run-export-all 6 golden_segmentation
run-export-all project_id slug:
    uv run run/export_run.py --project-id {{project_id}} --slug {{slug}} --all

# Run tokenizer on artifacts.csv for an existing run_id and write overlays/labels.
# Fast mode defaults to tokenize_dump with parallel workers and image dedupe.
# Usage: just run-tokenize 20260321-185915-text_fields [dump|desktopctl] [jobs]
run-tokenize RUN ENGINE="dump" JOBS="0":
    cargo build --release -p desktopctld --bin tokenize_dump --manifest-path ../src/desktop/Cargo.toml
    python3 run/run_tokenizer_overlays.py --run-dir "datasets/runs/$(basename '{{RUN}}')" --overwrite --engine "{{ENGINE}}" --jobs "{{JOBS}}"

# Incremental tokenize rerun: keep existing results and only fill missing labels.
# Usage: just run-tokenize-resume 20260321-185915-text_fields [dump|desktopctl] [jobs]
run-tokenize-resume RUN ENGINE="dump" JOBS="0":
    python3 run/run_tokenizer_overlays.py --run-dir "datasets/runs/$(basename '{{RUN}}')" --engine "{{ENGINE}}" --jobs "{{JOBS}}" --skip-existing

# Import tokenizer results for a run into Label Studio.
# Usage: just run-import 20260321-143000-text_fields
run-import RUN:
    uv run import/import_batch.py --dir "datasets/runs/$(basename '{{RUN}}')/results" --project "$(basename '{{RUN}}')" --run

# Log run labels from Label Studio to MLflow.
# Usage: just run-log 20260321-143000-text_fields
run-log RUN:
    uv run run/log_run.py "$(basename '{{RUN}}')"

# Create a new run folder from a filtered subset of an existing run.
# VERDICT: comma-separated, e.g. follow_up or accept,follow_up
# Usage: just run-subset datasets/runs/20260321-185915-text_fields follow_up my_slug
run-subset SOURCE VERDICT SLUG:
    uv run run/subset_run.py --source "{{SOURCE}}" --verdict "{{VERDICT}}" --slug "{{SLUG}}"

# Create focused label subset with image+overlay+label+metadata
# for accepted/gold rows and text-field-boundary comments.
# Usage: just run-focus-set 20260321-185915-text_fields
run-focus-set RUN:
    python3 run/create_focus_label_set.py --run-dir "datasets/runs/$(basename '{{RUN}}')" --overwrite
