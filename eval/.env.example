# Copy to .env and fill in values.

# Postgres
POSTGRES_USER=desktopctl
POSTGRES_PASSWORD=changeme

# Label Studio
LS_SECRET_KEY=changeme-secret-key
LS_URL=http://localhost:8080
LS_API_KEY=                        # from LS UI: Account & Settings → Access Token

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001

# Path on your Mac that gets mounted into Label Studio as /data/local-files.
# Batch dirs must live under here. Default: eval/datasets/
DATA_DIR=/path/to/desktopctl/eval/datasets
