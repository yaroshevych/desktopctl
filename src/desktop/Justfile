set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

workspace_dir := justfile_directory()
dist_dir := workspace_dir + "/dist"
app_dir := dist_dir + "/DesktopCtl.app"
contents_dir := app_dir + "/Contents"
macos_dir := contents_dir + "/MacOS"
cli_path := macos_dir + "/desktopctl"
legacy_cli_path := dist_dir + "/desktopctl"
stable_runtime_dir := workspace_dir + "/runtime-stable"
stable_app_dir := stable_runtime_dir + "/DesktopCtl.app"
stable_cli_path := stable_app_dir + "/Contents/MacOS/desktopctl"
stable_legacy_cli_path := stable_runtime_dir + "/desktopctl"
manifest_path := workspace_dir + "/Cargo.toml"
windows_msvc_target := "x86_64-pc-windows-msvc"
windows_gnu_target := "x86_64-pc-windows-gnu"
windows_arm64_target := "aarch64-pc-windows-gnullvm"

build:
  cd {{workspace_dir}} && cargo build --release -p desktopctld -p desktopctl
  rm -rf {{app_dir}}
  mkdir -p {{macos_dir}} {{contents_dir}}/Resources {{dist_dir}}
  cp {{workspace_dir}}/target/release/desktopctld {{macos_dir}}/desktopctld
  cp {{workspace_dir}}/target/release/desktopctl {{cli_path}}
  ln -sfn ./DesktopCtl.app/Contents/MacOS/desktopctl {{legacy_cli_path}}
  cp {{workspace_dir}}/daemon/packaging/macos/Info.plist {{contents_dir}}/Info.plist
  printf 'APPL????' > {{contents_dir}}/PkgInfo
  swift {{workspace_dir}}/scripts/gen_icns.swift {{contents_dir}}/Resources/AppIcon.icns
  chmod +x {{macos_dir}}/desktopctld {{cli_path}}
  codesign --force --sign - {{cli_path}} >/dev/null 2>&1 || true
  codesign --force --deep --sign - {{app_dir}} >/dev/null 2>&1 || true
  echo "Built: {{app_dir}}"
  echo "Built: {{cli_path}}"
  echo "Linked: {{legacy_cli_path}} -> ./DesktopCtl.app/Contents/MacOS/desktopctl"

build-windows:
  if [[ "$(uname -s)" == MINGW* || "$(uname -s)" == MSYS* || "$(uname -s)" == CYGWIN* || "$(uname -s)" == Windows_NT ]]; then \
    just -f {{workspace_dir}}/Justfile build-windows-msvc; \
  else \
    just -f {{workspace_dir}}/Justfile build-windows-gnu; \
  fi

build-windows-msvc:
  cd {{workspace_dir}} && rustup target add {{windows_msvc_target}}
  cd {{workspace_dir}} && cargo build --release --target {{windows_msvc_target}}
  echo "Built: {{workspace_dir}}/target/{{windows_msvc_target}}/release/desktopctl.exe"
  echo "Built: {{workspace_dir}}/target/{{windows_msvc_target}}/release/desktopctld.exe"

build-windows-gnu:
  cd {{workspace_dir}} && rustup target add {{windows_gnu_target}}
  cd {{workspace_dir}} && cargo build --release --target {{windows_gnu_target}} -p desktopctl
  cd {{workspace_dir}} && cargo build --release --target {{windows_gnu_target}} -p desktopctld
  echo "Built: {{workspace_dir}}/target/{{windows_gnu_target}}/release/desktopctl.exe"
  echo "Built: {{workspace_dir}}/target/{{windows_gnu_target}}/release/desktopctld.exe"

build-windows-arm64:
  if ! command -v aarch64-w64-mingw32-clang >/dev/null 2>&1; then echo "missing aarch64-w64-mingw32-clang; install with: brew install llvm-mingw"; exit 2; fi
  cd {{workspace_dir}} && rustup target add {{windows_arm64_target}}
  cd {{workspace_dir}} && cargo build --release --target {{windows_arm64_target}} -p desktopctl -p desktopctld
  echo "Built: {{workspace_dir}}/target/{{windows_arm64_target}}/release/desktopctl.exe"
  echo "Built: {{workspace_dir}}/target/{{windows_arm64_target}}/release/desktopctl-cli.exe"
  echo "Built: {{workspace_dir}}/target/{{windows_arm64_target}}/release/desktopctld.exe"

package-macos-arm64 tag:
  if [[ -z "{{tag}}" ]]; then echo "usage: just package-macos-arm64 <tag>"; exit 2; fi
  if [[ "$(uname -s)" != "Darwin" || "$(uname -m)" != "arm64" ]]; then echo "package-macos-arm64 must run on macOS arm64"; exit 2; fi
  just -f {{workspace_dir}}/Justfile build
  mkdir -p {{dist_dir}}/release
  cd {{dist_dir}} && ditto -c -k --sequesterRsrc --keepParent DesktopCtl.app release/DesktopCtl-{{tag}}-macos-arm64.zip
  echo "Built: {{dist_dir}}/release/DesktopCtl-{{tag}}-macos-arm64.zip"

package-windows-x64 tag target="x86_64-pc-windows-gnu":
  if [[ -z "{{tag}}" ]]; then echo "usage: just package-windows-x64 <tag> [target]"; exit 2; fi
  cd {{workspace_dir}} && rustup target add {{target}}
  cd {{workspace_dir}} && cargo build --release --target {{target}} -p desktopctl -p desktopctld
  rm -rf {{dist_dir}}/release/windows-x64 {{dist_dir}}/release/DesktopCtl-{{tag}}-windows-x64.zip
  mkdir -p {{dist_dir}}/release/windows-x64/DesktopCtl
  cp {{workspace_dir}}/target/{{target}}/release/desktopctl.exe {{dist_dir}}/release/windows-x64/DesktopCtl/
  cp {{workspace_dir}}/target/{{target}}/release/desktopctl-cli.exe {{dist_dir}}/release/windows-x64/DesktopCtl/
  cp {{workspace_dir}}/target/{{target}}/release/desktopctld.exe {{dist_dir}}/release/windows-x64/DesktopCtl/
  cd {{dist_dir}}/release/windows-x64 && zip -qr ../DesktopCtl-{{tag}}-windows-x64.zip DesktopCtl
  echo "Built: {{dist_dir}}/release/DesktopCtl-{{tag}}-windows-x64.zip"

package-windows-arm64 tag target="aarch64-pc-windows-gnullvm":
  if [[ -z "{{tag}}" ]]; then echo "usage: just package-windows-arm64 <tag> [target]"; exit 2; fi
  if ! command -v aarch64-w64-mingw32-clang >/dev/null 2>&1; then echo "missing aarch64-w64-mingw32-clang; install with: brew install llvm-mingw"; exit 2; fi
  cd {{workspace_dir}} && rustup target add {{target}}
  cd {{workspace_dir}} && cargo build --release --target {{target}} -p desktopctl -p desktopctld
  rm -rf {{dist_dir}}/release/windows-arm64 {{dist_dir}}/release/DesktopCtl-{{tag}}-windows-arm64.zip
  mkdir -p {{dist_dir}}/release/windows-arm64/DesktopCtl
  cp {{workspace_dir}}/target/{{target}}/release/desktopctl.exe {{dist_dir}}/release/windows-arm64/DesktopCtl/
  cp {{workspace_dir}}/target/{{target}}/release/desktopctl-cli.exe {{dist_dir}}/release/windows-arm64/DesktopCtl/
  cp {{workspace_dir}}/target/{{target}}/release/desktopctld.exe {{dist_dir}}/release/windows-arm64/DesktopCtl/
  cd {{dist_dir}}/release/windows-arm64 && zip -qr ../DesktopCtl-{{tag}}-windows-arm64.zip DesktopCtl
  echo "Built: {{dist_dir}}/release/DesktopCtl-{{tag}}-windows-arm64.zip"

package-release-assets tag:
  if [[ -z "{{tag}}" ]]; then echo "usage: just package-release-assets <tag>"; exit 2; fi
  just -f {{workspace_dir}}/Justfile package-macos-arm64 "{{tag}}"
  just -f {{workspace_dir}}/Justfile package-windows-x64 "{{tag}}"
  just -f {{workspace_dir}}/Justfile package-windows-arm64 "{{tag}}"
  echo "Release assets are in: {{dist_dir}}/release"

release-all tag target="main" repo="yaroshevych/desktopctl":
  if [[ -z "{{tag}}" ]]; then echo "usage: just release-all <tag> [target] [repo]"; exit 2; fi
  if ! command -v gh >/dev/null 2>&1; then echo "gh CLI is required. Install with: brew install gh"; exit 1; fi
  just -f {{workspace_dir}}/Justfile package-release-assets "{{tag}}"
  assets=( {{dist_dir}}/release/DesktopCtl-{{tag}}-*.zip ); \
  if [[ ! -e "${assets[0]}" ]]; then echo "no release assets found in {{dist_dir}}/release"; exit 1; fi; \
  if gh release view "{{tag}}" --repo "{{repo}}" >/dev/null 2>&1; then \
    gh release upload "{{tag}}" "${assets[@]}" --repo "{{repo}}" --clobber; \
  else \
    gh release create "{{tag}}" "${assets[@]}" --repo "{{repo}}" --target "{{target}}" --title "{{tag}}" --generate-notes; \
  fi
  echo "Release ready: https://github.com/{{repo}}/releases/tag/{{tag}}"

run: build
  open {{app_dir}}

clean:
  pkill -f desktopctld || true
  rm -f /tmp/desktopctl.sock
  rm -f /private/tmp/desktopctld.trace.log /private/tmp/desktopctl.cli.trace.log
  rm -rf /private/tmp/desktopctl-captures/*
  rm -rf {{dist_dir}}

clean-all:
  just clean
  rm -rf {{workspace_dir}}/target

stable-runtime-refresh build_first="1":
  if [[ "{{build_first}}" == "1" ]]; then \
    just -f {{workspace_dir}}/Justfile build; \
  fi
  rm -rf {{stable_app_dir}}
  rm -f {{stable_legacy_cli_path}}
  mkdir -p {{stable_runtime_dir}}
  cp -R {{app_dir}} {{stable_app_dir}}
  ln -sfn ./DesktopCtl.app/Contents/MacOS/desktopctl {{stable_legacy_cli_path}}
  chmod +x {{stable_cli_path}} {{stable_app_dir}}/Contents/MacOS/desktopctld
  codesign --force --sign - {{stable_cli_path}} >/dev/null 2>&1 || true
  codesign --force --deep --sign - {{stable_app_dir}} >/dev/null 2>&1 || true
  echo "Stable runtime refreshed:"
  echo "  {{stable_app_dir}}"
  echo "  {{stable_cli_path}}"
  echo "  {{stable_legacy_cli_path}} -> ./DesktopCtl.app/Contents/MacOS/desktopctl"

vm-enable-permissions vm_host="" vm_user="" vm_window_app="":
  DESKTOP_WORKSPACE_DIR="{{workspace_dir}}" \
  "{{workspace_dir}}/scripts/vm/enable_permissions.sh" \
    "{{vm_host}}" "{{vm_user}}" "{{vm_window_app}}"

vm-tokenize-phase0 vm_host="" vm_user="" vm_window_app="" run_dir="":
  DESKTOP_WORKSPACE_DIR="{{workspace_dir}}" \
  "{{workspace_dir}}/scripts/vm/tokenize_phase0.sh" \
    "{{vm_host}}" "{{vm_user}}" "{{vm_window_app}}" "{{run_dir}}"

vm-tokenize-phase1 vm_host="" vm_user="" vm_window_app="" run_dir="":
  DESKTOP_WORKSPACE_DIR="{{workspace_dir}}" \
  "{{workspace_dir}}/scripts/vm/tokenize_phase1_capture.sh" \
    "{{vm_host}}" "{{vm_user}}" "{{vm_window_app}}" "{{run_dir}}"

vm-smoke vm_host="" vm_user="" vm_window_app="" iterations="1":
  DESKTOP_WORKSPACE_DIR="{{workspace_dir}}" \
  "{{workspace_dir}}/scripts/vm/smoke.sh" \
    "{{vm_host}}" "{{vm_user}}" "{{vm_window_app}}" "{{iterations}}"

test-compile:
  cd {{workspace_dir}} && cargo test -p desktopctl --manifest-path {{manifest_path}} --no-run
  cd {{workspace_dir}} && cargo test -p desktopctld --manifest-path {{manifest_path}} --no-run

test-regression:
  cd {{workspace_dir}} && cargo test -p desktopctld --manifest-path {{manifest_path}} --test fixtures_contract -- --nocapture
  cd {{workspace_dir}} && cargo test -p desktopctld --manifest-path {{manifest_path}} --test text_field_button_labels -- --nocapture --test-threads=1
  just -f {{workspace_dir}}/Justfile test-compile
  just -f {{workspace_dir}}/Justfile check-cli-reference

release-gates:
  cd {{workspace_dir}} && cargo fmt --all --check
  just -f {{workspace_dir}}/Justfile test-regression

release-gates-strict:
  just -f {{workspace_dir}}/Justfile release-gates
  cd {{workspace_dir}} && cargo clippy --workspace --all-targets -- -D warnings

release tag target="main" repo="yaroshevych/desktopctl" demo_asset="":
  if [[ -z "{{tag}}" ]]; then echo "usage: just release <tag> [target] [repo] [demo_asset]"; exit 2; fi
  if ! command -v gh >/dev/null 2>&1; then echo "gh CLI is required. Install with: brew install gh"; exit 1; fi
  just -f {{workspace_dir}}/Justfile build
  cd {{dist_dir}} && ditto -c -k --sequesterRsrc --keepParent DesktopCtl.app "/tmp/DesktopCtl-{{tag}}-macos.zip"
  assets=("/tmp/DesktopCtl-{{tag}}-macos.zip"); if [[ -n "{{demo_asset}}" ]]; then assets+=("{{demo_asset}}"); fi; gh release create "{{tag}}" "${assets[@]}" --repo "{{repo}}" --target "{{target}}" --title "{{tag}}" --generate-notes
  echo "Release created:"
  echo "  tag: {{tag}}"
  echo "  repo: {{repo}}"
  echo "  target: {{target}}"
  echo "  asset: /tmp/DesktopCtl-{{tag}}-macos.zip"

check-cli-reference:
  "{{workspace_dir}}/scripts/dev/check_cli_reference.sh"

test-smoke:
  cd {{workspace_dir}} && \
    DESKTOPCTL_SMOKE=1 \
    DESKTOPCTL_SMOKE_BIN={{cli_path}} \
    cargo test -p desktopctl --manifest-path {{manifest_path}} --test smoke -- --nocapture --test-threads=1
