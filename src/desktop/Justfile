set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

workspace_dir := justfile_directory()
dist_dir := workspace_dir + "/dist"
app_dir := dist_dir + "/DesktopCtl.app"
contents_dir := app_dir + "/Contents"
macos_dir := contents_dir + "/MacOS"
cli_path := dist_dir + "/desktopctl"

build:
  cd {{workspace_dir}} && cargo build --release -p desktopctld -p desktopctl
  rm -rf {{app_dir}}
  mkdir -p {{macos_dir}} {{dist_dir}}
  cp {{workspace_dir}}/target/release/desktopctld {{macos_dir}}/desktopctld
  cp {{workspace_dir}}/target/release/desktopctl {{cli_path}}
  cp {{workspace_dir}}/daemon/packaging/macos/Info.plist {{contents_dir}}/Info.plist
  printf 'APPL????' > {{contents_dir}}/PkgInfo
  chmod +x {{macos_dir}}/desktopctld {{cli_path}}
  codesign --force --sign - {{cli_path}} >/dev/null 2>&1 || true
  codesign --force --deep --sign - {{app_dir}} >/dev/null 2>&1 || true
  echo "Built: {{app_dir}}"
  echo "Built: {{cli_path}}"

run: build
  open {{app_dir}}

clean:
  rm -rf {{dist_dir}} {{workspace_dir}}/target

vm-enable-permissions vm_host="" vm_user="" vm_window_app="":
  #!/usr/bin/env bash
  set -euo pipefail

  ENV_FILE="{{workspace_dir}}/.env"
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi

  VM_HOST_INPUT="{{vm_host}}"
  VM_USER_INPUT="{{vm_user}}"
  VM_WINDOW_APP_INPUT="{{vm_window_app}}"

  VM_HOST="${VM_HOST_INPUT:-${VM_HOST:-}}"
  VM_USER="${VM_USER_INPUT:-${VM_USER:-}}"
  VM_WINDOW_APP="${VM_WINDOW_APP_INPUT:-${VM_WINDOW_APP:-UTM}}"
  HOST_RETURN_APP="${HOST_RETURN_APP:-}"

  if [[ -z "$VM_HOST" ]]; then
    echo "Missing VM host. Set VM_HOST in src/desktop/.env or pass it to just vm-enable-permissions <vm_host> <vm_user>."
    exit 1
  fi
  if [[ -z "$VM_USER" ]]; then
    echo "Missing VM user. Set VM_USER in src/desktop/.env or pass it to just vm-enable-permissions <vm_host> <vm_user>."
    exit 1
  fi

  HOST_DCTL="{{cli_path}}"
  VM_APP_DIR="/Users/${VM_USER}/DesktopCtl/dist"
  VM_APP_PATH="${VM_APP_DIR}/DesktopCtl.app"
  VM_CLI_PATH="${VM_APP_DIR}/desktopctl"

  if [[ -z "$HOST_RETURN_APP" ]]; then
    HOST_RETURN_APP="$(/usr/bin/osascript -e 'tell application "System Events" to get name of first process whose frontmost is true' 2>/dev/null || true)"
  fi

  if [[ ! -x "$HOST_DCTL" ]]; then
    just build
  fi

  if [[ -z "${VM_OS_PASSWORD:-}" ]]; then
    read -r -s -p "VM macOS password (for Settings unlock prompts): " VM_OS_PASSWORD
    echo
  fi

  echo "[1/7] Build host artifacts"
  just build

  echo "[2/7] Copy artifacts to VM (${VM_HOST})"
  ssh "$VM_HOST" "mkdir -p '$VM_APP_DIR'"
  scp -r "{{app_dir}}" "$VM_HOST:$VM_APP_DIR/"
  scp "{{cli_path}}" "$VM_HOST:$VM_APP_DIR/"
  ssh "$VM_HOST" "chmod +x '$VM_CLI_PATH' '$VM_APP_PATH/Contents/MacOS/desktopctld'"

  echo "[3/7] Stop old daemon in VM"
  ssh "$VM_HOST" "pkill -f desktopctld || true; pkill -f 'DesktopCtl.app' || true"

  echo "[4/7] Focus VM window on host"
  if [[ -n "$HOST_RETURN_APP" && "$HOST_RETURN_APP" != "$VM_WINDOW_APP" ]]; then
    "$HOST_DCTL" app hide "$HOST_RETURN_APP" || true
  fi
  "$HOST_DCTL" open "$VM_WINDOW_APP" --wait

  normalize_host_workspace() {
    local target_app="$1"
    /usr/bin/osascript \
      -e 'on run argv' \
      -e 'set targetName to item 1 of argv' \
      -e 'tell application "System Events"' \
      -e 'repeat with p in (application processes whose background only is false)' \
      -e 'set pname to (name of p) as text' \
      -e 'if pname is not targetName then' \
      -e 'try' \
      -e 'set visible of p to false' \
      -e 'end try' \
      -e 'end if' \
      -e 'end repeat' \
      -e 'end tell' \
      -e 'tell application targetName to activate' \
      -e 'delay 0.25' \
      -e 'tell application "Finder" to set screenBounds to bounds of window of desktop' \
      -e 'set screenW to (item 3 of screenBounds) - (item 1 of screenBounds)' \
      -e 'set screenH to (item 4 of screenBounds) - (item 2 of screenBounds)' \
      -e 'tell application "System Events"' \
      -e 'tell process targetName' \
      -e 'set frontmost to true' \
      -e 'if (count of windows) > 0 then' \
      -e 'try' \
      -e 'set position of front window to {12, 38}' \
      -e 'set size of front window to {screenW - 24, screenH - 90}' \
      -e 'end try' \
      -e 'end if' \
      -e 'end tell' \
      -e 'end tell' \
      -e 'end run' \
      "$target_app"
  }

  normalize_host_workspace "$VM_WINDOW_APP"

  run_host_dctl() {
    normalize_host_workspace "$VM_WINDOW_APP"
    "$HOST_DCTL" "$@"
  }

  run_host_dctl_soft() {
    normalize_host_workspace "$VM_WINDOW_APP"
    "$HOST_DCTL" "$@" || true
  }

  add_entry_in_current_pane() {
    run_host_dctl_soft ui click --text "DesktopCtl" --timeout 1200
    run_host_dctl_soft ui click --settings-remove
    run_host_dctl wait 220

    run_host_dctl ui click --settings-add \
      || run_host_dctl ui click --text-offset "No Items" --dx -182 --dy 20 --timeout 1800 \
      || run_host_dctl ui click --text-offset "Allow the applications" --dx -170 --dy 46 --timeout 1800
    run_host_dctl wait --text "Open" --timeout 6000
    run_host_dctl key press cmd+shift+g
    run_host_dctl type "$VM_APP_DIR"
    run_host_dctl key press enter
    run_host_dctl wait --text "DesktopCtl.app" --timeout 6000
    run_host_dctl ui click --text "DesktopCtl.app" --timeout 3000
    run_host_dctl ui click --text "Open" --timeout 3000
    run_host_dctl wait 380
  }

  ensure_row_enabled() {
    local row_text="$1"
    if run_host_dctl ui settings enable "$row_text" --timeout 1600; then
      return 0
    fi
    run_host_dctl ui settings unlock --password "$VM_OS_PASSWORD" --timeout 2800
    run_host_dctl ui settings enable "$row_text" --timeout 1600
  }

  echo "[5/7] Configure Accessibility pane in VM"
  ssh "$VM_HOST" "open 'x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility'"
  run_host_dctl wait --text "Allow the applications below to control your computer." --timeout 14000
  add_entry_in_current_pane
  ensure_row_enabled "DesktopCtl"

  echo "[6/7] Configure Screen Recording pane in VM"
  ssh "$VM_HOST" "open 'x-apple.systempreferences:com.apple.preference.security?Privacy_ScreenCapture'"
  run_host_dctl wait --text "Allow the applications below to record the contents of your screen and system audio." --timeout 14000
  add_entry_in_current_pane
  ensure_row_enabled "DesktopCtl"
  run_host_dctl ui click --text "Quit & Reopen" --timeout 2500 || run_host_dctl_soft ui click --text "Later" --timeout 1500

  echo "[7/7] Verify in VM over SSH"
  ssh "$VM_HOST" "DESKTOPCTL_APP_PATH='$VM_APP_PATH' '$VM_CLI_PATH' permissions check"
  ssh "$VM_HOST" "DESKTOPCTL_APP_PATH='$VM_APP_PATH' '$VM_CLI_PATH' screen capture --out /tmp/dctl-cap.png"
  ssh "$VM_HOST" "DESKTOPCTL_APP_PATH='$VM_APP_PATH' '$VM_CLI_PATH' screen snapshot --json"
  ssh "$VM_HOST" "DESKTOPCTL_APP_PATH='$VM_APP_PATH' '$VM_CLI_PATH' screen tokenize --json"

  if [[ -n "$HOST_RETURN_APP" && "$HOST_RETURN_APP" != "$VM_WINDOW_APP" ]]; then
    "$HOST_DCTL" app show "$HOST_RETURN_APP" || true
  fi
  echo "Done: VM permissions and basic verification completed."
