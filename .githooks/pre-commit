#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_rust=()
while IFS= read -r path; do
  staged_rust+=("$path")
done < <(git diff --cached --name-only --diff-filter=ACMR -- ':(glob)src/desktop/**/*.rs')

if [[ "${#staged_rust[@]}" -eq 0 ]]; then
  exit 0
fi

cargo fmt --all --manifest-path src/desktop/Cargo.toml

if ! git diff --quiet -- "${staged_rust[@]}"; then
  echo "pre-commit: formatting updated staged Rust files under src/desktop."
  echo "pre-commit: review and stage changes, then commit again."
  git diff --name-only -- "${staged_rust[@]}"
  exit 1
fi
