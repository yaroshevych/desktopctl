{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug dictionary dark",
      "cargo": {
        "args": [
          "test",
          "-p", "desktopctld",
          "--test", "golden_labels",
          "--no-run",
          "--manifest-path", "${workspaceFolder}/src/desktop/Cargo.toml"
        ],
        "filter": {
          "kind": "test",
          "name": "golden_labels"
        }
      },
      "args": ["debug_dictionary_dark", "--nocapture"],
      "env": {
        "HIDE_GT": "1",
        "TOKENIZE_DEBUG": "1"
      },
      "cwd": "${workspaceFolder}/src/desktop"
    },
    {
